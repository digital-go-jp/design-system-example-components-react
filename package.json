{
  "name": "@digital-go-jp/design-system-example-components-react",
  "version": "2.7.0",
  "type": "module",
  "main": "dist/index.cjs.js",
  "typings": "dist/index.d.ts",
  "module": "dist/index.es.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs.js",
      "import": "./dist/index.es.js"
    }
  },
  "files": [
    "dist"
  ],
  "homepage": "https://github.com/digital-go-jp/design-system-example-components#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/digital-go-jp/design-system-example-components"
  },
  "bugs": {
    "url": "https://github.com/digital-go-jp/design-system-example-components/issues"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org",
    "access": "public"
  },
  "license": "MIT",
  "scripts": {
    "build": "tsc && vite build",
    "format": "biome format --write src",
    "lint": "biome lint src",
    "lint:fix": "biome check --write src",
    "lint:markup": "markuplint \"./src/**/*.{jsx,tsx}\"",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest --run",
    "test:setup": "playwright install chromium",
    "test:storybook": "vitest --project=storybook --run",
    "test:unit": "vitest --project=unit --run"
  },
  "dependencies": {
    "@digital-go-jp/design-tokens": "^2.0.1",
    "@digital-go-jp/tailwind-theme-plugin": "^1.0.1",
    "@internationalized/date": "^3.12.2",
    "react": "^18.3.1",
    "react-aria-components": "^1.19.0",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.19"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.3",
    "@markuplint/jsx-parser": "^4.18.3",
    "@markuplint/react-spec": "^4.18.0",
    "@storybook/addon-a11y": "^10.5.0",
    "@storybook/addon-docs": "^10.5.0",
    "@storybook/addon-links": "^10.5.0",
    "@storybook/addon-vitest": "^10.5.0",
    "@storybook/react-vite": "^10.5.0",
    "@tailwindcss/container-queries": "^0.1.1",
    "@tsconfig/node22": "^22.0.5",
    "@types/node": "^24.13.3",
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/browser-playwright": "^4.1.10",
    "autoprefixer": "^10.5.2",
    "markuplint": "^4.18.3",
    "playwright": "^1.61.1",
    "postcss": "^8.5.19",
    "storybook": "^10.5.0",
    "typescript": "^6.0.3",
    "vite": "^8.1.4",
    "vitest": "^4.1.10",
    "vitest-browser-react": "^2.2.0"
  },
  "engines": {
    "node": ">=22"
  },
  "engineStrict": true,
  "overrides": {
    "minimatch": ">=10.2.3"
  }
}
